# ============================================================
# GenAI Gateway - Ortam Değişkenleri Şablonu
# ============================================================
# Bu dosyayı kopyalayın: cp .env.template .env
# Ardından .env dosyasındaki değerleri kendi bilgilerinizle doldurun.
# .env dosyasını ASLA git'e eklemeyin!
# ============================================================

# Veritabanı Ayarları
USE_SQLITE="false"              # "true" yaparsanız PostgreSQL yerine SQLite kullanır (geliştirme için)
DB_HOST="db"                    # Docker: "db" | Lokal: "localhost"
DB_PORT="5432"
DB_NAME="genai_gateway"
DB_USER="postgres"
DB_PASSWORD="BURAYA_SIFRENIZI_YAZIN"

# Gemini API Anahtarları (https://aistudio.google.com/app/apikey adresinden alın)
GEMINI_API_KEY="BURAYA_GEMINI_API_KEY_YAZIN"
GEMINI_API_KEY_2="BURAYA_GEMINI_API_KEY_2_YAZIN"
GEMINI_API_KEY_3="BURAYA_GEMINI_API_KEY_3_YAZIN"
GEMINI_API_KEY_4="BURAYA_GEMINI_API_KEY_4_YAZIN"

# Google OAuth (https://console.cloud.google.com adresinden alın)
GOOGLE_CLIENT_ID="BURAYA_GOOGLE_CLIENT_ID_YAZIN"
GOOGLE_CLIENT_SECRET="BURAYA_GOOGLE_CLIENT_SECRET_YAZIN"

# GitHub OAuth (https://github.com/settings/developers adresinden alın)
GITHUB_CLIENT_ID="BURAYA_GITHUB_CLIENT_ID_YAZIN"
GITHUB_CLIENT_SECRET="BURAYA_GITHUB_CLIENT_SECRET_YAZIN"

# JWT Gizli Anahtarı (en az 32 karakter rastgele bir string)
JWT_SECRET="BURAYA_UZUN_RASTGELE_BIR_STRING_YAZIN_MIN_32_KARAKTER"

# OAuth Callback URL'leri
OAUTH_REDIRECT_GOOGLE="http://localhost:8000/api/v1/auth/google/callback"
OAUTH_REDIRECT_GITHUB="http://localhost:8000/api/v1/auth/github/callback"
